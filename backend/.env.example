# Gemini API
GEMINI_API_KEY=your_api_key_here

# Server Config
HOST=0.0.0.0
PORT=8000
DEBUG=True

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Database (PostgreSQL)
DATABASE_URL=postgresql://aiko_user:aiko_password_2026@localhost:5432/aiko_db
DB_ECHO=False  # Set to True for SQL query logging

# Session Config
SESSION_DURATION_HOURS=24
MAX_MESSAGES_PER_SESSION=100

# Authentication & Security
JWT_SECRET_KEY=your-super-secret-jwt-key-min-32-characters-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Qdrant Vector Database
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=aiko_memories

# RAG Configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2
MEMORY_SEARCH_LIMIT=5
MEMORY_RELEVANCE_THRESHOLD=0.7

# Security & Rate Limiting
RATE_LIMIT_REQUESTS=100  # Max requests per window (per user/IP)
RATE_LIMIT_WINDOW_SECONDS=3600  # Time window in seconds (1 hour)
WEBSOCKET_RATE_LIMIT_MESSAGES=30  # Max WebSocket messages per minute
WEBSOCKET_RATE_LIMIT_WINDOW=60  # WebSocket rate limit window (1 minute)
MAX_MESSAGE_LENGTH=5000  # Maximum chat message length
ENABLE_SECURITY_HEADERS=True  # Enable security headers middleware